{
  "name": "@solarwinds-apm/sampling",
  "version": "3.2.1",
  "license": "Apache-2.0",
  "contributors": [
    "Raphaël Thériault <raphael.theriault@solarwinds.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solarwinds/apm-js.git",
    "directory": "packages/sampling"
  },
  "bugs": {
    "url": "https://github.com/solarwinds/apm-js/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "./src/",
    "./dist/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "lint": "prettier --check . && eslint . --max-warnings=0",
    "lint:fix": "eslint --fix . && prettier --write .",
    "release": "node ../../scripts/publish.js",
    "scan": "node ../../scripts/scan.js",
    "test": "swtest -p test/tsconfig.json -c src"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@solarwinds-apm/module": "workspace:^"
  },
  "peerDependencies": {
    "@opentelemetry/api": "catalog:"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": false
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@solarwinds-apm/eslint-config": "workspace:^",
    "@solarwinds-apm/test": "workspace:^",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
