{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "build.js",
        "build.*.js",
        "package.json",
        "tsconfig.json",
        "src/**"
      ],
      "outputs": ["dist/**", ".next/**", "COMPATIBILITY.md"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "release": {
      "dependsOn": ["^release"]
    },
    "scan": {
      "dependsOn": [],
      "inputs": ["package.json"],
      "outputs": ["*.tgz"]
    },
    "start": {
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["@solarwinds-apm/test#build", "build"],
      "inputs": ["package.json", "tsconfig.json", "src/**", "test/**"]
    }
  },
  "globalDependencies": [
    ".prettierrc.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "tsconfig.base.json",
    "tsconfig.base.test.json",
    "packages/eslint-config/index.js"
  ],
  "globalPassThroughEnv": [
    "SW_APM_*",
    "OTEL_*",
    "PNPM_*",
    "GITHUB_*",
    "AWS_LAMBDA_*",
    "NODE_*",
    "CI"
  ]
}
